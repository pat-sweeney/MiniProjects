{
  "name": "nas-slideshow",
  "version": "1.0.0",
  "description": "Electron + React slideshow app with facial recognition, voice control, and LLM tagging",
  "main": "./out/main/index.js",
  "author": "pat-sweeney",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "py:install": "python -m pip install -r python/requirements.txt",
    "py:run": "python python/sidecar.py",
    "py:bundle": "python -m PyInstaller --clean --noconfirm --distpath dist-sidecar sidecar.spec",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:dir": "npm run build && electron-builder --dir"
  },
  "dependencies": {
    "electron-updater": "^6.2.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.1.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.3",
    "vite": "^5.3.3"
  },
  "build": {
    "appId": "com.patsweeney.nasslideshow",
    "productName": "NAS Slideshow",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "build/icon.png",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "pat-sweeney",
        "repo": "MiniProjects"
      }
    ],
    "extraResources": [
      {
        "from": "python",
        "to": "python",
        "filter": [
          "**/*",
          "!__pycache__/**",
          "!.venv/**",
          "!*.pyc",
          "!slideshow.db"
        ]
      },
      {
        "from": "dist-sidecar",
        "to": "python",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "icon": "build/icon.png",
      "target": "dmg",
      "category": "public.app-category.photography"
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage"
      ],
      "category": "Graphics"
    }
  }
}
